   <string notr="true">
/* ===== 全局 ===== */
QWidget#menu {
    font-family: &quot;Helvetica Neue&quot;,&quot;PingFang SC&quot;,&quot;Microsoft YaHei&quot;,sans-serif;
}

/* ===== 视频区 ===== */
QLabel#cap_Frame_lb {
    background-color: #000000;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 18px;
}

/* ===== 控制面板 - Apple卡片风格 ===== */
QStackedWidget#ctl_Panel_sw {
    background: rgba(30,30,30,0.7);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
}

/* ===== PTZ按钮 - 圆形胶囊 ===== */
QPushButton#turn_up_bt,
QPushButton#turn_down_bt,
QPushButton#turn_left_bt,
QPushButton#turn_right_bt {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 14px;
}
QPushButton#turn_up_bt:hover,
QPushButton#turn_down_bt:hover,
QPushButton#turn_left_bt:hover,
QPushButton#turn_right_bt:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.3);
}

/* ===== 中心复位 ===== */
QPushButton#turn_reset_bt {
    background: rgba(255,59,48,0.2);
    border: 1px solid rgba(255,59,48,0.4);
    border-radius: 14px;
}
QPushButton#turn_reset_bt:hover {
    background: rgba(255,59,48,0.35);
}

/* ===== 拍照/录像 ===== */
QPushButton#get_photo_bt,
QPushButton#get_vedio_bt {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 16px;
}
QPushButton#get_photo_bt:hover,
QPushButton#get_vedio_bt:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.3);
}

/* ===== 底部导航 - Apple式粗圆角卡片 ===== */
QPushButton#swt_Control_bt,
QPushButton#exp_Check_bt,
QPushButton#file_Manage_bt,
QPushButton#mode_Setup_bt {
    background: rgba(28,28,30,0.75);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 22px;
    color: #ffffff;
    font-size: 14px;
    font-weight: 500;
    padding-top: 50px;
}
QPushButton#swt_Control_bt:hover,
QPushButton#exp_Check_bt:hover,
QPushButton#file_Manage_bt:hover,
QPushButton#mode_Setup_bt:hover {
    background: rgba(44,44,46,0.85);
    border-color: rgba(255,255,255,0.2);
}
   </string>
