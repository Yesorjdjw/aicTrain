<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>setup</class>
 <widget class="QWidget" name="setup">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1024</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>模式设置</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* 全局 */
QWidget#setup {
    background-color: #d6e8f5;
    border-radius: 16px;
    font-family: &quot;Helvetica Neue&quot;,&quot;PingFang SC&quot;,&quot;Microsoft YaHei&quot;,sans-serif;
}
/* 卡片 */
QFrame#leftCard, QFrame#rightCard {
    background: #ffffff;
    border: none;
    border-radius: 14px;
}
/* 标题栏 */
QWidget#leftTitleBar, QWidget#rightTitleBar {
    background-color: #1a7bbd;
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
}
QLabel#leftTitleText {
    color: #ffffff; font-size: 14px; font-weight: 600; background: transparent; letter-spacing: 1px;
}
QLabel#rightTitle {
    color: #ffffff; font-size: 13px; font-weight: 600; background: transparent;
}
/* 子模块标题 */
QLabel#moduleTitle {
    color: #333333; font-size: 14px; font-weight: 600; background: transparent;
}
/* 设置项标签 */
QLabel#settingLabel {
    color: #333333; font-size: 13px; font-weight: 500; background: transparent;
}
QLabel#settingDesc {
    color: #888888; font-size: 11px; background: transparent;
}
/* 导航按钮 */
QPushButton#nav1, QPushButton#nav2, QPushButton#nav3, QPushButton#nav4, QPushButton#nav5 {
    background: transparent; border: none; text-align: left;
    font-size: 13px; font-weight: 500; color: #333333; padding-left: 44px;
}
QPushButton#nav1:hover, QPushButton#nav2:hover, QPushButton#nav3:hover,
QPushButton#nav4:hover, QPushButton#nav5:hover { background: #eef4fa; }
/* 复选框 - iOS风格开关 */
QCheckBox {
    spacing: 8px; font-size: 12px; color: #333333;
}
QCheckBox::indicator {
    width: 18px; height: 18px; border-radius: 4px;
    border: 2px solid #cccccc; background: #ffffff;
}
QCheckBox::indicator:checked {
    border: 2px solid #1a7bbd; background: #1a7bbd;
    image: url(:/images/icon_check.svg);
}
/* 开关式复选框 */
QCheckBox#toggleCruise { spacing: 10px; font-size: 13px; color: #333333; }
QCheckBox#toggleCruise::indicator {
    width: 44px; height: 24px; border-radius: 12px;
    border: none; background: #e0e0e0;
}
QCheckBox#toggleCruise::indicator:checked {
    background: #34c759;
}
QCheckBox#toggleCruise::indicator:checked {
    image: url(:/images/icon_toggle_on.svg);
}
/* 滑动条 */
QSlider#speedSlider::groove:horizontal {
    height: 6px; border-radius: 3px; background: #e0e0e0;
}
QSlider#speedSlider::handle:horizontal {
    width: 20px; height: 20px; margin: -7px 0; border-radius: 10px;
    background: #1a7bbd; border: none;
}
QSlider#speedSlider::sub-page:horizontal {
    background: #1a7bbd; border-radius: 3px;
}
/* 下拉框 */
QComboBox {
    background: #f5f5f7; border: 1px solid #e0e0e0; border-radius: 6px;
    padding: 6px 10px; font-size: 12px; color: #333333; min-width: 140px;
}
QComboBox:hover { border-color: #1a7bbd; }
QComboBox::drop-down { border: none; width: 20px; }
/* 时间输入框 */
QTimeEdit {
    background: #f5f5f7; border: 1px solid #e0e0e0; border-radius: 6px;
    padding: 6px 10px; font-size: 12px; color: #333333; min-width: 90px;
}
QTimeEdit:hover { border-color: #1a7bbd; }
/* 保存按钮 */
QPushButton#saveBt {
    background: #1a7bbd; border: none; border-radius: 8px;
    color: #ffffff; font-size: 13px; font-weight: 500; padding: 10px 28px;
}
QPushButton#saveBt:hover { background: #155d94; }
/* 恢复默认 */
QPushButton#resetBt {
    background: #ffffff; border: 1px solid #dddddd; border-radius: 8px;
    color: #888888; font-size: 13px; font-weight: 500; padding: 10px 20px;
}
QPushButton#resetBt:hover { border-color: #bbbbbb; color: #555555; }
/* 返回按钮 */
QPushButton#backBt {
    background: transparent; border: 1px solid rgba(26,123,189,0.25); border-radius: 14px;
    color: #1a7bbd; font-size: 12px; font-weight: 500; text-align: center;
}
QPushButton#backBt:hover { background: rgba(26,123,189,0.06); border-color: rgba(26,123,189,0.5); }
/* 子模块卡片 */
QFrame#subCard {
    background: transparent; border: 1px solid #f0f0f0; border-radius: 10px;
}
   </string>
